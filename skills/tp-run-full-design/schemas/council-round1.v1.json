{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:tp-run-full-design:council-round1:v1",
  "title": "tp-run-full-design council Round-1 verdict envelope",
  "description": "Round-1 verdict a council persona returns under /council --orchestrator --round 1. Travels between orchestrator and personas (not a slot return), so it stands alone rather than extending tier-return. Each findings[] item mirrors the audit-return.v1 finding shape so the synthesizer can carry per-finding confidence forward verbatim (F3).",
  "type": "object",
  "required": [
    "schema",
    "member",
    "verdict",
    "confidence",
    "findings",
    "argument_summary"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": {
      "const": "tp-run-full-design/council-round1/v1"
    },
    "member": {
      "type": "string",
      "minLength": 1
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "pass-with-notes", "needs-work"]
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["confidence", "category", "description", "suggested_fix"],
        "additionalProperties": true,
        "properties": {
          "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
          "category": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "suggested_fix": {"type": "string"},
          "where": {"type": "string"}
        }
      }
    },
    "argument_summary": {
      "type": "string"
    }
  }
}
