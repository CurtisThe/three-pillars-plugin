{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "tp-run-full-design/candidate/v1",
  "title": "tp-run-full-design candidate response",
  "description": "Structured response a worker Agent emits to the orchestrator under the candidate.v1 contract.",
  "type": "object",
  "required": [
    "schema",
    "candidate_id",
    "branch",
    "sha",
    "summary",
    "test_results",
    "telemetry"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": {
      "type": "string",
      "const": "tp-run-full-design/candidate/v1"
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "branch": {
      "type": "string",
      "pattern": "^candidate/[a-z0-9-]+/[a-z0-9-]+$"
    },
    "sha": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "summary": {
      "type": "string"
    },
    "test_results": {
      "type": "object",
      "required": ["passed", "failed", "skipped", "raw"],
      "additionalProperties": true,
      "properties": {
        "passed": {"type": "integer", "minimum": 0},
        "failed": {"type": "integer", "minimum": 0},
        "skipped": {"type": "integer", "minimum": 0},
        "raw": {"type": "string"}
      }
    },
    "telemetry": {
      "type": "object",
      "required": ["duration_ms", "tokens_used", "tool_calls"],
      "additionalProperties": true,
      "properties": {
        "duration_ms": {"type": "integer", "minimum": 0},
        "tokens_used": {"type": ["integer", "null"], "minimum": 0},
        "tool_calls": {"type": "integer", "minimum": 0}
      }
    }
  }
}
