{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:tp-run-full-design:audit-return:v1",
  "title": "tp-run-full-design audit tier return",
  "description": "Return envelope for audit-class slots (design-audit, plan-audit, impl-audit). Extends the base tier-return via allOf and adds a verdict plus structured findings the orchestrator uses for retry-with-advice and escalation.",
  "allOf": [
    {"$ref": "urn:tp-run-full-design:tier-return:v1"},
    {
      "if": {"required": ["verdict"], "properties": {"verdict": {"const": "needs-work"}}},
      "then": {"properties": {"findings": {"minItems": 1}}}
    }
  ],
  "type": "object",
  "required": [
    "verdict",
    "findings"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": {
      "const": "tp-run-full-design/audit-return/v1"
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "pass-with-notes", "needs-work"]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["confidence", "category", "description", "suggested_fix"],
        "additionalProperties": true,
        "properties": {
          "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
          "category": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "suggested_fix": {"type": "string"}
        }
      }
    }
  }
}
