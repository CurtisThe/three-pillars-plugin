{
  "permissions": {
    "allow": [
      "Bash(python -m pytest:*)"
    ],
    "deny": [
      "Bash(git commit --no-verify:*)",
      "Bash(git commit -n:*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "test -x ~/.claude/statusline.sh && ~/.claude/statusline.sh || true",
    "padding": 1
  },
  "skipDangerousModePermissionPrompt": false
}
