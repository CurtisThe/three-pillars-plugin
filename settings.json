{
  "permissions": {
    "allow": [
      "Bash(python -m pytest:*)"
    ],
    "deny": [
      "Bash(git commit --no-verify:*)",
      "Bash(git commit -n:*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 1
  },
  "skipDangerousModePermissionPrompt": false
}
